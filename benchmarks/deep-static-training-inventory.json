{
  "version": 1,
  "repositories": [
    {
      "id": "juice-shop",
      "name": "Juice Shop challenge category inventory",
      "source": {
        "kind": "juice-shop-challenges",
        "relativePath": "data/static/challenges.yml"
      },
      "categoryCoverage": {
        "Broken Access Control": {
          "groundTruthIds": ["juice.access-control", "juice.ssrf"],
          "note": "Covers route/resource authorization and SSRF challenge classes; UI-only discovery remains a later challenge-level gate."
        },
        "Broken Anti Automation": {
          "groundTruthIds": [
            "juice.anti-automation-captcha-rate",
            "juice.anti-automation-extra-language",
            "juice.anti-automation-multiple-likes",
            "juice.password-reset-security-questions"
          ],
          "note": "Covers CAPTCHA rate abuse, hidden language resource enumeration, duplicate-like race behavior, and the password-reset brute-force overlap."
        },
        "Broken Authentication": {
          "groundTruthIds": [
            "juice.credential-trust",
            "juice.password-reset-security-questions",
            "juice.two-factor-token-trust"
          ]
        },
        "Cryptographic Issues": {
          "groundTruthIds": ["juice.coupon-encoding-trust", "juice.jwt-token-trust"],
          "note": "Covers reversible coupon logic and JWT/token trust; challenge-level inventory still needs weird-crypto and paywall-specific expectations."
        },
        "Improper Input Validation": {
          "groundTruthIds": [
            "juice.access-control",
            "juice.coupon-encoding-trust",
            "juice.upload-validation"
          ]
        },
        "Injection": {
          "groundTruthIds": [
            "juice.sql-injection",
            "juice.nosql",
            "juice.ssti",
            "juice.llm-tool-prompt-trust"
          ]
        },
        "Insecure Deserialization": {
          "groundTruthIds": ["juice.insecure-deserialization-rce"]
        },
        "Miscellaneous": {
          "groundTruthIds": ["juice.web3-wallet-withdrawal-reentrancy"],
          "note": "Covers the security-relevant Wallet Depletion smart-contract withdrawal risk; scoreboard, privacy-policy acknowledgement, security.txt etiquette, notification clearing, and CSAF checksum submission are product discovery or runtime/due-diligence goals rather than static code-path vulnerabilities."
        },
        "Observability Failures": {
          "groundTruthIds": ["juice.file-exposure", "juice.ssrf"],
          "note": "Covers log/file exposure and metrics fetch paths; leaked-log semantics should become a challenge-level expectation."
        },
        "Security Misconfiguration": {
          "groundTruthIds": [
            "juice.security-misconfiguration-deprecated-interface",
            "juice.security-misconfiguration-error-handling",
            "juice.security-misconfiguration-login-support",
            "juice.security-misconfiguration-svg-imaging"
          ]
        },
        "Security through Obscurity": {
          "groundTruthIds": [
            "juice.obscurity-token-sale-route",
            "juice.obscurity-privacy-policy-proof",
            "juice.obscurity-hidden-image"
          ],
          "note": "Covers obfuscated frontend route discovery, hidden private asset proof routes, and static steganography clue exposure."
        },
        "Sensitive Data Exposure": {
          "groundTruthIds": [
            "juice.hardcoded-secrets",
            "juice.file-exposure",
            "juice.credential-trust",
            "juice.password-reset-security-questions"
          ]
        },
        "Unvalidated Redirects": {
          "groundTruthIds": ["juice.open-redirect"]
        },
        "Vulnerable Components": {
          "groundTruthIds": [
            "juice.vulnerable-components",
            "juice.jwt-token-trust",
            "juice.file-exposure"
          ]
        },
        "XSS": {
          "groundTruthIds": ["juice.xss"]
        },
        "XXE": {
          "groundTruthIds": ["juice.xxe"]
        }
      }
    }
  ]
}
