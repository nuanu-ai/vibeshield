{
  "name": "vibeshield",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": ">=24"
  },
  "bin": {
    "vibeshield": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "cli": "tsx src/cli.ts",
    "scan": "tsx src/cli.ts scan",
    "smoke:daytona": "tsx scripts/smoke-daytona.ts",
    "smoke:pi-daytona": "tsx scripts/smoke-pi-daytona.ts",
    "lint": "biome check .",
    "resume": "tsx src/cli.ts resume",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.5",
    "@types/node": "^24.0.0",
    "@types/pdfkit": "^0.17.6",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "@daytona/sdk": "^0.187.0",
    "dotenv": "^17.4.2",
    "jsonrepair": "^3.14.0",
    "pdfkit": "^0.19.1"
  }
}
